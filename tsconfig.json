{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "useUnknownInCatchVariables": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/Redux",
    "src/proxy.ts",
    "src/CommonComponents/BreadCrumb.tsx",
    "src/Component/Bookmarks",
    "src/Component/Contacts",
    "src/Component/Dashboard/Ecommerce",
    "src/Component/Ecommerce",
    "src/Component/Email",
    "src/Component/Header/Searchbar",
    "src/Component/Header/RightHeader/Bookmarks",
    "src/Component/KnowledgeBaseMain",
    "src/Component/Tasks",
    "src/Component/ThemeCustomizer",
    "src/Component/To-do",
    "src/Component/Widgets",
    "src/Component/chat",
    "src/Data/EcommerceData",
    "src/Component/Dashboard/Default/ProfileGreetingCard.tsx",
    "src/Component/Icons",
    "src/Component/DataTable",
    "src/Component/bonus-ui/Tour",
    "src/Component/FormWidgets",
    "src/Component/UiKits",
    "src/Component/SupportTicket"
  ]
}
